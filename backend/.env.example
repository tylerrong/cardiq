# CardIQ price aggregator — config. Copy to .env and fill what you have.
PORT=8787

# pokemontcg.io (TCGplayer + Cardmarket prices). Works without a key (rate-limited).
POKEMONTCG_API_KEY=

# PriceCharting — graded values sourced from eBay sales. Paid API token.
# https://www.pricecharting.com/api-documentation
PRICECHARTING_TOKEN=

# eBay Marketplace Insights (sold/completed items, 90-day history).
# LIMITED ACCESS — must apply: https://developer.ebay.com/api-docs/buy/static/api-insights.html
# Provide an OAuth application/access token once approved.
EBAY_OAUTH_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_US
